{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@everyapi-ai/gateway": [
        "./src/gateway/index.ts"
      ],
      "@everyapi-ai/agent-contract": [
        "./src/agent-contract/index.ts"
      ],
      "@everyapi-ai/agent-core": [
        "./src/agent-core/index.ts"
      ]
    },
    "types": [
      "node"
    ],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true
  },
  "include": [
    "src/**/*"
  ]
}
